---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Sagarika Ramesh, Senior Data Scientist building forecasting systems, LLM pipelines, and analytics infrastructure."
		/>
		<title>Sagarika Ramesh | Senior Data Scientist</title>
		<script is:inline>
			if ('scrollRestoration' in history) {
				history.scrollRestoration = 'manual';
			}
			if (!window.location.hash) {
				window.scrollTo(0, 0);
			}
		</script>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<style>
			.section {
				@apply py-12;
			}
			#project-modal-backdrop {
				opacity: 0;
				transition: opacity 0.35s ease;
			}
			#project-modal-panel {
				transform: translateY(2rem);
				opacity: 0;
				transition:
					transform 0.35s ease,
					opacity 0.35s ease;
			}
			#project-modal.is-open #project-modal-backdrop {
				opacity: 1;
			}
			#project-modal.is-open #project-modal-panel {
				transform: translateY(0);
				opacity: 1;
			}
		</style>
	</head>
	<body class="bg-paper font-sans text-ink antialiased">
		<!-- Navbar -->
		<header
			class="fixed inset-x-0 top-0 z-50 border-b border-ink/10 bg-paper/90 backdrop-blur-md"
		>
			<nav
				class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4"
				aria-label="Main navigation"
			>
				<a
					href="#top"
					class="font-serif text-xl font-normal tracking-tight transition-opacity hover:opacity-70 sm:text-2xl"
				>
					Sagarika Ramesh
				</a>

				<ul class="hidden items-center gap-8 md:flex">
					{
						navLinks.map(({ href, label }) => (
							<li>
								<a
									href={href}
									class="text-sm font-medium tracking-wide text-ink/70 transition-colors hover:text-ink"
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>

				<button
					id="menu-toggle"
					type="button"
					class="flex h-10 w-10 items-center justify-center md:hidden"
					aria-expanded="false"
					aria-controls="mobile-menu"
					aria-label="Toggle navigation menu"
				>
					<svg
						id="menu-icon-open"
						class="h-6 w-6"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="1.5"
							d="M4 6h16M4 12h16M4 18h16"></path>
					</svg>
					<svg
						id="menu-icon-close"
						class="hidden h-6 w-6"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
						aria-hidden="true"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="1.5"
							d="M6 18L18 6M6 6l12 12"></path>
					</svg>
				</button>
			</nav>

			<div
				id="mobile-menu"
				class="hidden border-t border-ink/10 bg-paper md:hidden"
			>
				<ul class="flex flex-col px-6 py-4">
					{
						navLinks.map(({ href, label }) => (
							<li>
								<a
									href={href}
									class="mobile-nav-link block py-3 text-base font-medium text-ink/70 transition-colors hover:text-ink"
								>
									{label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</header>

		<main>
			<!-- Hero -->
			<section
				id="top"
				class="mx-auto min-h-[70vh] max-w-6xl px-6 pt-20"
			>
				<div
					class="flex flex-col items-start gap-10 pt-24 lg:flex-row lg:items-start lg:gap-16"
				>
				<!-- Symbol portrait: top on mobile, right on desktop -->
				<div
					class="order-1 -mt-10 flex w-full shrink-0 justify-center lg:order-2 lg:w-auto lg:justify-end"
				>
					<canvas
						id="portrait-canvas"
						class="h-[340px] w-[280px] md:h-[420px] md:w-[380px]"
						aria-label="Animated portrait made of linear algebra, calculus, and statistics symbols"
						role="img"
					></canvas>
					<canvas id="portrait-source" class="hidden" aria-hidden="true"
					></canvas>
				</div>

				<!-- Text content: below canvas on mobile, left on desktop -->
				<div class="order-2 flex flex-col lg:order-1">
					<p class="text-sm font-medium tracking-wide text-ink/50">
						Senior Data Scientist · Austin, TX
					</p>
					<h1
						class="mt-3 font-serif text-5xl leading-[1.05] tracking-tight sm:text-6xl md:text-7xl lg:text-6xl xl:text-7xl"
					>
						Turning messy data into <span class="text-teal">decisions.</span>
					</h1>
					<p
						class="mt-8 max-w-2xl text-lg leading-relaxed text-ink/70 md:text-xl"
					>
						I turn complex, high stakes data into production grade ML systems
						and decision intelligence. My work spans across forecasting, LLM
						agents, and advanced analytics across industries where accuracy
						drives operations.
					</p>
					<div class="mt-10 flex flex-wrap items-center gap-6">
						<a
							href="#work"
							class="inline-flex items-center bg-ink px-7 py-3.5 text-sm font-medium tracking-wide text-paper transition-opacity hover:opacity-85"
						>
							See my work
						</a>
						<a
							href="#contact"
							class="text-sm font-medium tracking-wide text-ink underline decoration-ink/30 underline-offset-4 transition-colors hover:text-teal hover:decoration-teal"
						>
							Get in touch
						</a>
					</div>
				</div>
				</div>
			</section>

			<!-- Work -->
			<section id="work" class="section border-t border-ink/10 px-6">
				<div class="mx-auto max-w-6xl">
					<div
						class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
					>
						<h2 class="font-serif text-4xl tracking-tight md:text-5xl">Experience</h2>
						<button
							id="work-view-toggle"
							type="button"
							class="inline-flex w-fit items-center border border-ink px-5 py-2.5 text-sm font-medium tracking-wide transition-colors hover:bg-ink hover:text-paper"
						>
							Fun projects
						</button>
					</div>

					<div id="work-experience-panel" class="mt-12">
						<div
							id="work-grid"
							class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
						>
							{
								workProjects.map((project, index) => (
									<article
										class:list={[
											'project-card work-project-card group relative flex cursor-pointer flex-col border border-ink/20 bg-paper p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-teal/50 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal active:translate-y-0 active:shadow-sm',
											index >= INITIAL_WORK_VISIBLE && 'work-card-collapsed hidden',
										]}
										data-project-list="work"
										data-project-index={index}
										tabindex="0"
										role="button"
										aria-label={`View details for ${project.title}`}
									>
										{project.year && (
											<p class="absolute right-6 top-6 text-xs font-medium tabular-nums text-ink/45">
												{project.year}
											</p>
										)}
										<p class="pr-16 text-xs text-ink/60">
											{project.hideClientLabel ? (
												<span class="font-medium text-ink/75">
													{project.client}
												</span>
											) : (
												<>
													<span class="font-medium text-ink/75">Client:</span>{' '}
													{project.client}
												</>
											)}
										</p>
										<h3 class="mt-2 font-serif text-xl leading-snug transition-colors group-hover:text-teal md:text-2xl">
											{project.title}
										</h3>
										<p class="mt-3 flex-1 text-sm leading-relaxed text-ink/65">
											{project.description}
										</p>
										<ul class="mt-5 flex flex-wrap gap-2">
											{project.tags.map((tag) => (
												<li>
													<span class="inline-block border border-ink/15 px-2.5 py-1 text-xs font-medium tracking-wide text-ink/60">
														{tag}
													</span>
												</li>
											))}
										</ul>
										<p class="mt-5 flex items-center gap-1.5 text-xs font-medium tracking-wide text-ink/50 transition-colors group-hover:text-teal">
											View details
											<span
												class="transition-transform duration-200 group-hover:translate-x-0.5"
												aria-hidden="true">→</span>
										</p>
									</article>
								))
							}
						</div>
						{
							workProjects.length > INITIAL_WORK_VISIBLE && (
								<div class="mt-10 flex justify-center">
									<button
										id="work-expand-btn"
										type="button"
										class="inline-flex items-center gap-2 text-sm font-medium tracking-wide text-ink/60 transition-colors hover:text-teal"
										aria-expanded="false"
									>
										<span id="work-expand-label">Show all experience</span>
										<svg
											id="work-expand-icon"
											class="h-4 w-4 transition-transform duration-200"
											fill="none"
											stroke="currentColor"
											viewBox="0 0 24 24"
											aria-hidden="true"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												stroke-width="1.5"
												d="M19 9l-7 7-7-7"
											/>
										</svg>
									</button>
								</div>
							)
						}
					</div>

					<div id="side-projects-panel" class="mt-12 hidden">
						<div
							id="side-grid"
							class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
						>
							{
								sideProjects.map((project, index) => (
									<article
										class="project-card side-project-card group relative flex cursor-pointer flex-col border border-ink/20 bg-paper p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-teal/50 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal active:translate-y-0 active:shadow-sm"
										data-project-list="side"
										data-project-index={index}
										tabindex="0"
										role="button"
										aria-label={`View details for ${project.title}`}
									>
										{project.year && (
											<p class="absolute right-6 top-6 text-xs font-medium tabular-nums text-ink/45">
												{project.year}
											</p>
										)}
										<p class="pr-16 text-xs font-medium text-ink/75">Side project</p>
										<h3 class="mt-2 font-serif text-xl leading-snug transition-colors group-hover:text-teal md:text-2xl">
											{project.title}
										</h3>
										<p class="mt-3 flex-1 text-sm leading-relaxed text-ink/65">
											{project.description}
										</p>
										<ul class="mt-5 flex flex-wrap gap-2">
											{project.tags.map((tag) => (
												<li>
													<span class="inline-block border border-ink/15 px-2.5 py-1 text-xs font-medium tracking-wide text-ink/60">
														{tag}
													</span>
												</li>
											))}
										</ul>
										<p class="mt-5 flex items-center gap-1.5 text-xs font-medium tracking-wide text-ink/50 transition-colors group-hover:text-teal">
											View details
											<span
												class="transition-transform duration-200 group-hover:translate-x-0.5"
												aria-hidden="true">→</span>
										</p>
									</article>
								))
							}
						</div>
					</div>
				</div>
			</section>

			<!-- Project modal -->
			<div
				id="project-modal"
				class="fixed inset-0 z-[100] hidden"
				aria-hidden="true"
				role="dialog"
				aria-modal="true"
				aria-labelledby="modal-title"
			>
				<div
					id="project-modal-backdrop"
					class="absolute inset-0 bg-ink/60"
				></div>
				<div
					class="pointer-events-none relative flex h-full items-center justify-center px-4 py-8 sm:px-6"
				>
					<div
						class="pointer-events-auto flex w-full max-w-4xl items-center gap-2 sm:gap-4"
					>
						<button
							id="modal-prev"
