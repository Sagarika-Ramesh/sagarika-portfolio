		<script>
			// Portrait canvas: linear algebra, calculus, and stats symbols forming a photo
			(function initPortrait() {
				const LINEAR_ALGEBRA = [
					'×',
					'·',
					'λ',
					'⊗',
					'⊕',
					'∈',
					'ℝ',
					'⊤',
					'∥',
					'⟨',
					'⟩',
					'|',
				];
				const CALCULUS = [
					'∂',
					'∇',
					'∫',
					'∮',
					'∑',
					'∏',
					'∞',
					'π',
					'ε',
					'Δ',
				];
				const STATS = [
					'μ',
					'σ',
					'χ',
					'ρ',
					'β',
					'α',
					'θ',
					'ν',
					'φ',
					'ψ',
					'Φ',
					'Ψ',
				];
				const SYMBOLS = [...LINEAR_ALGEBRA, ...CALCULUS, ...STATS];

				function pickChar() {
					return SYMBOLS[Math.floor(Math.random() * SYMBOLS.length)];
				}

				const SYMBOL_COLOR = '#00C8A0';
				const WHITE_THRESHOLD = 200;

				const canvas = document.getElementById('portrait-canvas');
				const sourceCanvas = document.getElementById('portrait-source');
				if (!canvas || !sourceCanvas) return;

				const ctx = canvas.getContext('2d');
				const sourceCtx = sourceCanvas.getContext('2d');
				if (!ctx || !sourceCtx) return;

				/** @type {{ ox: number; oy: number; x: number; y: number; targetX: number; targetY: number; returnFromX: number; returnFromY: number; char: string; size: number; opacity: number }[]} */
				let particles = [];
				let canvasW = 0;
				let canvasH = 0;
				let initialized = false;
				let listenersBound = false;
				let animFrameId = 0;
				let animMode = 'idle';
				let returnStart = 0;
				let returnDuration = 800;
				let mobileReturnTimeout = 0;

				const SAMPLE_STEP = 4;

				function isMobile() {
					return window.innerWidth < 768;
				}

				function getSize() {
					if (!isMobile()) {
						return { w: 380, h: 420 };
					}
					return { w: 280, h: 340 };
				}

				function getCanvasPoint(clientX, clientY) {
					const rect = canvas.getBoundingClientRect();
					const scaleX = canvas.width / rect.width;
					const scaleY = canvas.height / rect.height;
					return {
						x: (clientX - rect.left) * scaleX,
						y: (clientY - rect.top) * scaleY,
					};
				}

				function brightness(r, g, b) {
					return r * 0.299 + g * 0.587 + b * 0.114;
				}

				function opacityForBrightness(value) {
					return Math.min(1.0, (1 - value / 255) * 1.5);
				}

				function shouldSamplePixel(r, g, b) {
					if (r > 210 && g > 210 && b > 210) return false;
					return brightness(r, g, b) <= WHITE_THRESHOLD;
				}

				function sizeForBrightness(value) {
					if (value < 80) return 7 + Math.random() * 2;
					if (value <= 160) return 5 + Math.random() * 2;
					return 4 + Math.random() * 1;
				}

				function buildParticles(img) {
					const { w, h } = getSize();
					canvasW = w;
					canvasH = h;
					canvas.width = w;
					canvas.height = h;
					sourceCanvas.width = w;
					sourceCanvas.height = h;

					sourceCtx.drawImage(img, 0, 0, w, h);
					const { data } = sourceCtx.getImageData(0, 0, w, h);
					particles = [];

					for (let y = 0; y < h; y += SAMPLE_STEP) {
						for (let x = 0; x < w; x += SAMPLE_STEP) {
							const i = (y * w + x) * 4;
							const r = data[i];
							const g = data[i + 1];
							const b = data[i + 2];
							if (!shouldSamplePixel(r, g, b)) continue;

							const lum = brightness(r, g, b);
							const opacity = opacityForBrightness(lum);
							if (opacity < 0.2) continue;

							const px = x + SAMPLE_STEP / 2;
							const py = y + SAMPLE_STEP / 2;
							particles.push({
								ox: px,
								oy: py,
								x: px,
								y: py,
								targetX: px,
								targetY: py,
								returnFromX: px,
								returnFromY: py,
								char: pickChar(),
								size: sizeForBrightness(lum),
								opacity,
							});
						}
					}
				}

				function draw() {
					ctx.clearRect(0, 0, canvasW, canvasH);

					for (const p of particles) {
						ctx.save();
						ctx.globalAlpha = p.opacity;
						ctx.fillStyle = SYMBOL_COLOR;
						ctx.font = `${p.size}px Inter, system-ui, sans-serif`;
						ctx.textAlign = 'center';
						ctx.textBaseline = 'middle';
						ctx.fillText(p.char, p.x, p.y);
						ctx.restore();
					}
				}

				function applyDisperse(px, py, radius) {
					const minFly = 80;
					const maxFly = 150;

					for (const p of particles) {
						const dx = p.ox - px;
						const dy = p.oy - py;
						const dist = Math.hypot(dx, dy);

						if (dist > radius || dist < 0.001) {
							p.targetX = p.ox;
							p.targetY = p.oy;
							continue;
						}

						const force = 1 - dist / radius;
						const fly = minFly + force * (maxFly - minFly);
						p.targetX = p.ox + (dx / dist) * fly;
						p.targetY = p.oy + (dy / dist) * fly;
					}
				}

				function stopAnimation() {
					cancelAnimationFrame(animFrameId);
					animFrameId = 0;
				}

				function tick(now) {
					if (animMode === 'interact') {
						let moving = false;

						for (const p of particles) {
							p.x += (p.targetX - p.x) * 0.28;
							p.y += (p.targetY - p.y) * 0.28;
							if (
								Math.abs(p.x - p.targetX) > 0.5 ||
								Math.abs(p.y - p.targetY) > 0.5
							) {
								moving = true;
							}
						}
						draw();

						if (moving) {
							animFrameId = requestAnimationFrame(tick);
						} else {
							animFrameId = 0;
						}
						return;
					}

					if (animMode === 'return') {
						const elapsed = now - returnStart;
						const t = Math.min(1, elapsed / returnDuration);
						const ease = 1 - (1 - t) ** 3;

						for (const p of particles) {
							p.x = p.returnFromX + (p.ox - p.returnFromX) * ease;
							p.y = p.returnFromY + (p.oy - p.returnFromY) * ease;
						}
						draw();

						if (t < 1) {
							animFrameId = requestAnimationFrame(tick);
						} else {
							for (const p of particles) {
								p.x = p.ox;
								p.y = p.oy;
								p.targetX = p.ox;
								p.targetY = p.oy;
							}
							animMode = 'idle';
							animFrameId = 0;
						}
					}
				}

				function startInteractLoop() {
					if (animMode === 'return') {
						stopAnimation();
					}
					animMode = 'interact';
					if (!animFrameId) {
						animFrameId = requestAnimationFrame(tick);
					}
				}

				function startReturn(delay = 0, duration = 800) {
					stopAnimation();
					clearTimeout(mobileReturnTimeout);

					const begin = () => {
						for (const p of particles) {
							p.returnFromX = p.x;
							p.returnFromY = p.y;
						}
						animMode = 'return';
						returnStart = performance.now();
						returnDuration = duration;
						animFrameId = requestAnimationFrame(tick);
					};

					if (delay > 0) {
						mobileReturnTimeout = setTimeout(begin, delay);
					} else {
						begin();
					}
				}

				function disperseFrom(x, y) {
					clearTimeout(mobileReturnTimeout);
					stopAnimation();
					applyDisperse(x, y, 120);
					animMode = 'interact';
					animFrameId = requestAnimationFrame(function interactTick() {
						let moving = false;

						for (const p of particles) {
							p.x += (p.targetX - p.x) * 0.28;
							p.y += (p.targetY - p.y) * 0.28;
							if (
								Math.abs(p.x - p.targetX) > 0.5 ||
								Math.abs(p.y - p.targetY) > 0.5
							) {
								moving = true;
							}
						}
						draw();

						if (moving) {
							animFrameId = requestAnimationFrame(interactTick);
							return;
						}

						for (const p of particles) {
							p.returnFromX = p.x;
							p.returnFromY = p.y;
						}
						animMode = 'return';
						returnStart = performance.now();
						returnDuration = 1000;
						animFrameId = requestAnimationFrame(tick);
					});
				}

				function bindInteractionListeners() {
					if (listenersBound) return;
					listenersBound = true;

					canvas.addEventListener('mousemove', (event) => {
						if (isMobile()) return;
						const { x, y } = getCanvasPoint(
							event.clientX,
							event.clientY,
						);
						applyDisperse(x, y, 100);
						startInteractLoop();
					});

					canvas.addEventListener('mouseleave', () => {
						if (isMobile()) return;
						startReturn(0, 800);
					});

					canvas.addEventListener(
						'touchstart',
						function (e) {
							e.preventDefault();
							const rect = canvas.getBoundingClientRect();
							const touch = e.touches[0];
							const touchX =
								(touch.clientX - rect.left) *
								(canvas.width / rect.width);
							const touchY =
								(touch.clientY - rect.top) *
								(canvas.height / rect.height);
							disperseFrom(touchX, touchY);
						},
						{ passive: false },
					);
				}

				function startPortrait() {
					if (initialized) return;
					initialized = true;

					const img = new Image();
					img.src = '/sagarika_2.jpg';
					img.onload = () => {
						buildParticles(img);
						draw();
						bindInteractionListeners();
					};
				}

				const portraitObserver = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								startPortrait();
								portraitObserver.disconnect();
							}
						}
					},
					{ rootMargin: '50px' },
				);
				portraitObserver.observe(canvas);

				let resizeTimer;
				window.addEventListener('resize', () => {
					if (!initialized) return;
					clearTimeout(resizeTimer);
					resizeTimer = setTimeout(() => {
						stopAnimation();
						clearTimeout(mobileReturnTimeout);
						animMode = 'idle';
						const img = new Image();
						img.src = '/sagarika_2.jpg';
						img.onload = () => {
							buildParticles(img);
							draw();
						};
					}, 200);
				});
			})();

			const menuToggle = document.getElementById('menu-toggle');
			const mobileMenu = document.getElementById('mobile-menu');
			const menuIconOpen = document.getElementById('menu-icon-open');
			const menuIconClose = document.getElementById('menu-icon-close');

			menuToggle?.addEventListener('click', () => {
				const isOpen = !mobileMenu?.classList.contains('hidden');
				mobileMenu?.classList.toggle('hidden', isOpen);
				menuIconOpen?.classList.toggle('hidden', !isOpen);
				menuIconClose?.classList.toggle('hidden', isOpen);
				menuToggle.setAttribute('aria-expanded', String(!isOpen));
			});

			if (!window.location.hash) {
				window.scrollTo(0, 0);
			}

			document.querySelectorAll('.mobile-nav-link').forEach((link) => {
				link.addEventListener('click', () => {
					mobileMenu?.classList.add('hidden');
					menuIconOpen?.classList.remove('hidden');
					menuIconClose?.classList.add('hidden');
					menuToggle?.setAttribute('aria-expanded', 'false');
				});
			});
		</script>

		<script define:vars={{ workProjects, sideProjects, INITIAL_WORK_VISIBLE }}>
			(function initWorkSection() {
				const modal = document.getElementById('project-modal');
				const backdrop = document.getElementById('project-modal-backdrop');
				const panel = document.getElementById('project-modal-panel');
				const closeBtn = document.getElementById('modal-close');
				const prevBtn = document.getElementById('modal-prev');
				const nextBtn = document.getElementById('modal-next');
				const modalClient = document.getElementById('modal-client');
				const modalClientPrefix = document.getElementById('modal-client-prefix');
				const modalClientLabel = document.getElementById('modal-client-label');
				const modalYear = document.getElementById('modal-year');
				const modalTitle = document.getElementById('modal-title');
				const modalDescription = document.getElementById('modal-description');
				const modalBullets = document.getElementById('modal-bullets');
				const modalTags = document.getElementById('modal-tags');
				const modalGithub = document.getElementById('modal-github');
				const workViewToggle = document.getElementById('work-view-toggle');
				const workExperiencePanel = document.getElementById('work-experience-panel');
				const sideProjectsPanel = document.getElementById('side-projects-panel');
				const workExpandBtn = document.getElementById('work-expand-btn');
				const workExpandLabel = document.getElementById('work-expand-label');
				const workExpandIcon = document.getElementById('work-expand-icon');

				if (
					!modal ||
					!backdrop ||
					!panel ||
					!closeBtn ||
					!prevBtn ||
					!nextBtn ||
					!modalClient ||
					!modalClientPrefix ||
					!modalClientLabel ||
					!modalYear ||
					!modalTitle ||
					!modalDescription ||
					!modalBullets ||
					!modalTags ||
					!modalGithub ||
					!workViewToggle ||
					!workExperiencePanel ||
					!sideProjectsPanel
				) {
					return;
				}

				let currentIndex = 0;
				let currentList = 'work';
				let isOpen = false;
				let isWorkExpanded = false;
				let showingSideProjects = false;

				function activeProjects() {
					return showingSideProjects ? sideProjects : workProjects;
				}

				function renderModal(index) {
					const project = activeProjects()[index];
					const isSide = showingSideProjects;

					if (isSide) {
						modalClientLabel.classList.remove('hidden');
						modalClientPrefix.classList.add('hidden');
						modalClient.classList.remove('ml-1');
						modalClient.classList.add('font-medium', 'text-ink/75');
						modalClient.textContent = 'Side project';
						modalYear.classList.add('hidden');
					} else if (project.hideClientLabel) {
						modalClientLabel.classList.remove('hidden');
						modalClientPrefix.classList.add('hidden');
						modalClient.classList.remove('ml-1');
						modalClient.classList.add('font-medium', 'text-ink/75');
						modalClient.textContent = project.client;
					} else {
						modalClientLabel.classList.remove('hidden');
						modalClientPrefix.classList.remove('hidden');
						modalClient.classList.add('ml-1');
						modalClient.classList.remove('font-medium', 'text-ink/75');
						modalClient.textContent = project.client;
					}

					if (project.year) {
						modalYear.textContent = project.year;
						modalYear.classList.remove('hidden');
					} else {
						modalYear.textContent = '';
						modalYear.classList.add('hidden');
					}

					modalTitle.textContent = project.title;
					modalDescription.textContent = project.description;

					modalBullets.innerHTML = project.bullets
						.map((bullet) => `<li>${bullet}</li>`)
						.join('');

					modalTags.innerHTML = project.tags
						.map(
							(tag) =>
								`<li><span class="inline-block border border-ink/15 px-2.5 py-1 text-xs font-medium tracking-wide text-ink/60">${tag}</span></li>`,
						)
						.join('');

					if (project.githubUrl) {
						modalGithub.href = project.githubUrl;
						modalGithub.classList.remove('hidden');
					} else {
						modalGithub.href = '#';
						modalGithub.classList.add('hidden');
					}
				}

				function openModal(list, index) {
					currentList = list;
					showingSideProjects = list === 'side';
					currentIndex = index;
					renderModal(currentIndex);
					modal.classList.remove('hidden');
					modal.setAttribute('aria-hidden', 'false');
					document.body.style.overflow = 'hidden';
					isOpen = true;

					requestAnimationFrame(() => {
						modal.classList.add('is-open');
					});
				}

				function closeModal() {
					if (!isOpen) return;
					modal.classList.remove('is-open');
					modal.setAttribute('aria-hidden', 'true');
					isOpen = false;
					document.body.style.overflow = '';

					setTimeout(() => {
						if (!isOpen) {
							modal.classList.add('hidden');
						}
					}, 350);
				}

				function navigate(delta) {
					const list = activeProjects();
					currentIndex = (currentIndex + delta + list.length) % list.length;
					renderModal(currentIndex);
					panel.scrollTop = 0;
				}

				function bindProjectCards() {
					document.querySelectorAll('.project-card').forEach((card) => {
						card.addEventListener('click', () => {
							const index = Number(card.getAttribute('data-project-index'));
							const list = card.getAttribute('data-project-list') || 'work';
							if (!Number.isNaN(index)) openModal(list, index);
						});

						card.addEventListener('keydown', (event) => {
							if (event.key === 'Enter' || event.key === ' ') {
								event.preventDefault();
								const index = Number(
									card.getAttribute('data-project-index'),
								);
								const list = card.getAttribute('data-project-list') || 'work';
								if (!Number.isNaN(index)) openModal(list, index);
							}
						});
					});
				}

				function setWorkExpanded(expanded) {
					isWorkExpanded = expanded;
					document.querySelectorAll('.work-card-collapsed').forEach((card) => {
						card.classList.toggle('hidden', !expanded);
					});

					if (workExpandBtn && workExpandLabel && workExpandIcon) {
						workExpandBtn.setAttribute('aria-expanded', String(expanded));
						workExpandLabel.textContent = expanded
							? 'Show less'
							: 'Show all experience';
						workExpandIcon.classList.toggle('rotate-180', expanded);
					}
				}

				if (workExpandBtn) {
					workExpandBtn.addEventListener('click', () => {
						setWorkExpanded(!isWorkExpanded);
					});
				}

				workViewToggle.addEventListener('click', () => {
					showingSideProjects = !showingSideProjects;
					workExperiencePanel.classList.toggle('hidden', showingSideProjects);
					sideProjectsPanel.classList.toggle('hidden', !showingSideProjects);
					workViewToggle.textContent = showingSideProjects
						? 'Work experience'
						: 'Fun projects';
				});

				closeBtn.addEventListener('click', closeModal);
				backdrop.addEventListener('click', closeModal);
				prevBtn.addEventListener('click', (event) => {
					event.stopPropagation();
					navigate(-1);
				});
				nextBtn.addEventListener('click', (event) => {
					event.stopPropagation();
					navigate(1);
				});

				panel.addEventListener('click', (event) => {
					event.stopPropagation();
				});

				modalGithub.addEventListener('click', (event) => {
					event.stopPropagation();
				});

				document.addEventListener('keydown', (event) => {
					if (!isOpen) return;

					if (event.key === 'Escape') {
						closeModal();
					} else if (event.key === 'ArrowLeft') {
						navigate(-1);
					} else if (event.key === 'ArrowRight') {
						navigate(1);
					}
				});

				bindProjectCards();
			})();
		</script>
	</body>
</html>
